[2026-03-09 11:36:49] [2b997390-3b1c-42e4-b3c9-fc83bdecffaa] TOOL: Write | INPUT: {"file_path":"/home/debian/Dev/nico_tools/nico_meets/src/console.ts","content":"import { NicoMeetsBridge } from \"./bridge\";\nimport { findChatContainer, extractText } from \"./dom\";\n\n// ---- Configuration (edit before pasting) ----\nconst NICO_MEETS_HOST = \"localhost\";\nconst NICO_MEETS_PORT = 29292;\n// ---------------------------------------------\n\n(function () {\n  if ((window as any).__nicoMeets) {\n    console.warn(\"[nico_meets] Already running. Use __nicoMeets.stop() first.\");\n    return;\n  }\n\n  const bridge = new NicoMeetsBridge({\n    host: NICO_MEETS_HOST,\n    port: NICO_MEETS_PORT,\n  });\n\n  let observer: MutationObserver | null = null;\n\n  function start() {\n    const container = findChatContainer(document);\n    if (!container) {\n      console.warn(\n        \"[nico_meets] Chat panel not found. Open the chat first, then run again.\"\n      );\n      return;\n    }\n\n    // Snapshot existing messages as \"seen\"\n    const existing = container.querySelectorAll(\"[data-message-id]\");\n    for (const msg of existing) {\n      const text = extractText(msg);\n      if (text) bridge.send(text); // send returns immediately for seen dedup\n    }\n    // Clear the dedup set and re-add existing so they won't fire again\n    // Actually, send() already adds them to seen set, so new ones won't duplicate\n\n    // Re-snapshot: mark existing as seen without sending\n    // We need a different approach - just snapshot IDs\n    const seenIds = new Set<string>();\n    for (const msg of existing) {\n      const id = msg.getAttribute(\"data-message-id\");\n      if (id) seenIds.add(id);\n    }\n\n    observer = new MutationObserver((mutations) => {\n      for (const mutation of mutations) {\n        for (const node of mutation.addedNodes) {\n          if (!(node instanceof Element)) continue;\n\n          const messages = node.matches(\"[data-message-id]\")\n            ? [node]\n            : Array.from(node.querySelectorAll(\"[data-message-id]\"));\n\n          for (const msg of messages) {\n            const id = msg.getAttribute(\"data-message-id\");\n            if (id && seenIds.has(id)) continue;\n            if (id) seenIds.add(id);\n\n            const text = extractText(msg);\n            if (text) bridge.send(text);\n          }\n        }\n      }\n    });\n\n    observer.observe(container, { childList: true, subtree: true });\n    console.log(\n      `[nico_meets] Started. Watching for new chat messages. Sending to http://${NICO_MEETS_HOST}:${NICO_MEETS_PORT}/comment`\n    );\n  }\n\n  function stop() {\n    if (observer) {\n      observer.disconnect();\n      observer = null;\n    }\n    (window as any).__nicoMeets = undefined;\n    console.log(\"[nico_meets] Stopped.\");\n  }\n\n  (window as any).__nicoMeets = { stop };\n  start();\n})();\n"}
