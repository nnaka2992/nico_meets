[2026-03-09 11:33:18] [2b997390-3b1c-42e4-b3c9-fc83bdecffaa] TOOL: Write | INPUT: {"file_path":"/home/debian/Dev/nico_tools/nico_meets/src/bridge.ts","content":"export interface BridgeOptions {\n  host: string;\n  port: number;\n}\n\nconst MAX_RUNES = 255;\n\nexport class NicoMeetsBridge {\n  private endpoint: string;\n  private seen = new Set<string>();\n\n  constructor(options: BridgeOptions) {\n    this.endpoint = `http://${options.host}:${options.port}/comment`;\n  }\n\n  async send(text: string): Promise<void> {\n    if (!text) return;\n    if (this.seen.has(text)) return;\n    this.seen.add(text);\n\n    const truncated = [...text].slice(0, MAX_RUNES).join(\"\");\n\n    try {\n      await fetch(this.endpoint, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ text: truncated }),\n      });\n    } catch (e) {\n      console.warn(\"[nico_meets] Could not reach nico_monitor:\", (e as Error).message);\n    }\n  }\n}\n"}
