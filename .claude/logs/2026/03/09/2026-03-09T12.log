[2026-03-09 12:52:52] [1d5c3289-82f5-47bd-941c-b7c9d068124c] TOOL: Edit | INPUT: {"file_path":"/home/debian/Dev/nico_tools/nico_meets/src/bridge.ts","old_string":"const MAX_RUNES = 255;\n\nexport class NicoMeetsBridge {\n  private endpoint: string;\n  private seen = new Set<string>();\n\n  constructor(options: BridgeOptions) {\n    this.endpoint = `http://${options.host}:${options.port}/comment`;\n  }\n\n  async send(text: string): Promise<void> {\n    if (!text) return;\n    if (this.seen.has(text)) return;\n    this.seen.add(text);","new_string":"const MAX_RUNES = 255;\nconst MAX_SEEN = 256;\n\nfunction addBounded(set: Set<string>, value: string): void {\n  if (set.size >= MAX_SEEN) {\n    const first = set.values().next().value!;\n    set.delete(first);\n  }\n  set.add(value);\n}\n\nexport class NicoMeetsBridge {\n  private endpoint: string;\n  private seen = new Set<string>();\n\n  constructor(options: BridgeOptions) {\n    this.endpoint = `http://${options.host}:${options.port}/comment`;\n  }\n\n  async send(text: string): Promise<void> {\n    if (!text) return;\n    if (this.seen.has(text)) return;\n    addBounded(this.seen, text);","replace_all":false}
