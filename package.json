{
  "name": "nico_meets",
  "version": "1.0.0",
  "description": "Google Meet chat bridge for nico_monitor",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "esbuild src/console.ts --bundle --format=iife --outfile=dist/nico_meets.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/jsdom": "^28.0.0",
    "esbuild": "^0.27.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
